fn div(a: int, b: int) -> int {
    if b == 0 {
        error("division by zero")
    }
    return a / b
}

flag = false
v = try div(42, 2) with error(resume, msg) {
    flag = true
}
assert(v == 21)
assert(not flag)

flag = false
v = try div(42, 0) with error(resume, msg) {
    flag = true
}
assert(v == null)
assert(flag)
